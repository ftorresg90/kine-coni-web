# =============================================================================
# .env.local.example — Kinesiología Coni Web
# =============================================================================
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local to version control.
#
# All variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All others are server-only (Route Handlers, Server Components, middleware).
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase
# Create a project at https://supabase.com and copy the values from:
# Project Settings → API → Project URL / anon public key
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Service role key — server-only, bypasses RLS. Used by cron routes.
# Supabase Dashboard → Settings → API → Project API keys → service_role
# NEVER prefix with NEXT_PUBLIC_ and NEVER use in client-side code.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...


# -----------------------------------------------------------------------------
# Telegram Bot — Notificaciones a la kinesióloga
# -----------------------------------------------------------------------------
# 1. Crea un bot hablando con @BotFather en Telegram: /newbot
# 2. Copia el token que te entrega (formato: 7123456789:AAH_xxxxx)
# 3. Inicia una conversación con tu bot y obtén el Chat ID enviando:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    El campo "chat" → "id" en la respuesta es el TELEGRAM_CHAT_ID.
#    Para grupos usa el ID negativo del grupo (ej. -1001234567890).
TELEGRAM_BOT_TOKEN=7123456789:AAH_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789


# -----------------------------------------------------------------------------
# Twilio — WhatsApp Business (notificaciones a pacientes)
# -----------------------------------------------------------------------------
# Crea una cuenta en https://twilio.com
# Account SID y Auth Token están en: Console Dashboard → Account Info
#
# Para el número de WhatsApp:
#   Sandbox (desarrollo): usa "whatsapp:+14155238886"
#     → El paciente debe enviar el código de invitación al sandbox primero.
#   Producción: conecta un número de WhatsApp Business aprobado por Meta.
#     → El número aprobado tiene el formato "whatsapp:+56XXXXXXXXX"
#
# IMPORTANTE — Ventana de 24 horas de WhatsApp Business:
#   Los mensajes fuera de una conversación activa (>24h sin respuesta del
#   paciente) requieren HSM (Highly Structured Messages / Content Templates)
#   pre-aprobados por Meta. Para mensajes de recordatorio automáticos:
#     1. Crea un Content Template en Twilio Console → Content Template Builder
#     2. Envíalo a revisión de Meta (puede tardar 24-48h)
#     3. Usa el ContentSid en lugar del campo Body en la petición a Twilio
#   El código actual usa Body (texto libre) que funciona en sandbox y dentro
#   de ventanas de conversación abiertas.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886


# -----------------------------------------------------------------------------
# Resend — Email (notificaciones a pacientes con email registrado)
# -----------------------------------------------------------------------------
# Crea una cuenta en https://resend.com (plan gratuito: 3 000 emails/mes)
# Obtén tu API Key en: Resend Dashboard → API Keys → Create API Key
#
# RESEND_FROM_EMAIL debe ser:
#   - Una dirección de un dominio verificado en Resend, O
#   - "onboarding@resend.dev" para pruebas (solo envía a tu propio email)
#
# Formato recomendado para producción:
#   "Constanza Anjarí Kinesiología <citas@tudominio.cl>"
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Constanza Anjarí Kinesiología <citas@tudominio.cl>


# -----------------------------------------------------------------------------
# Cron Secret — Protección de rutas de cron jobs
# -----------------------------------------------------------------------------
# Genera un secreto largo y aleatorio, por ejemplo con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Este valor debe configurarse también en:
#   - Vercel → Project Settings → Environment Variables (con ese nombre exacto)
#
# Vercel Cron Jobs (vercel.json) inyectan automáticamente el header
#   Authorization: Bearer <CRON_SECRET>
# en cada invocación cuando la variable existe en el entorno del proyecto.
# No es necesario configurar el header manualmente en vercel.json.
#
# Para servicios de cron externos (ej. cron-job.org) deberás configurar
# manualmente el header: Authorization: Bearer <CRON_SECRET>
#
# Rutas protegidas por este secret:
#   GET /api/notifications/remind          (recordatorios 24h — 09:00 Santiago)
#   GET /api/notifications/daily-summary   (resumen diario Telegram — 07:30 Santiago)
CRON_SECRET=reemplaza_con_un_string_aleatorio_de_al_menos_32_caracteres
